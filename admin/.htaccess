# ==============================================================
# ADMIN DIRECTORY — ACCESS RULES
# ==============================================================

# --- Block direct access to environment/config files ----------------
<FilesMatch "^\.env\.php$">
    <IfModule mod_authz_core.c>
        # Apache 2.4+
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        # Apache 2.2
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
