# ==============================================================
# ADMIN DIRECTORY — ACCESS RULES
# ==============================================================

# --- Block direct access to environment/config files ----------------
<FilesMatch "^\.env\.php$">
    <IfModule mod_authz_core.c>
        # Apache 2.4+
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        # Apache 2.2
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# --- PHP upload & memory limits (Apache mod_php) --------------------
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value memory_limit 128M
    php_value max_execution_time 120
</IfModule>

<IfModule mod_php7.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value memory_limit 128M
    php_value max_execution_time 120
</IfModule>
